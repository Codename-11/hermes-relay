{
  "name": "hermes-relay-dashboard",
  "version": "1.2.0",
  "private": true,
  "description": "Hermes-Relay dashboard plugin frontend (IIFE bundle). Loaded verbatim by the hermes-agent dashboard via the Plugin SDK global.",
  "scripts": {
    "build": "esbuild src/index.jsx --bundle --format=iife --target=es2020 --minify --outfile=dist/index.js --loader:.jsx=jsx --jsx=transform --jsx-factory=React.createElement --jsx-fragment=React.Fragment && node -e \"require('fs').copyFileSync('src/styles.css','dist/style.css')\"",
    "watch": "node -e \"require('fs').copyFileSync('src/styles.css','dist/style.css')\" && esbuild src/index.jsx --bundle --format=iife --target=es2020 --outfile=dist/index.js --loader:.jsx=jsx --jsx=transform --jsx-factory=React.createElement --jsx-fragment=React.Fragment --watch"
  },
  "devDependencies": {
    "esbuild": "^0.25.12",
    "qrcode": "^1.5.4"
  }
}
