#!/usr/bin/env bash
# hermes-pair — Generate QR code for pairing mobile devices with Hermes API server
# Reads connection details from ~/.hermes/.env and renders a scannable QR via qrencode.
# Usage: hermes-pair [--png] [--host HOST] [--port PORT]
#
# DEPRECATED: Use the hermes-relay plugin's `hermes pair` command instead.
# This script is kept for backward compatibility with hermes-agent v0.7.0 and earlier.
#   Install the plugin: cp -r plugin ~/.hermes/plugins/hermes-relay
#   Then run:           hermes pair
set -euo pipefail

echo "WARNING: 'hermes-pair' is deprecated. Use 'hermes pair' from the hermes-relay plugin." >&2
echo "         Install: cp -r plugin ~/.hermes/plugins/hermes-relay" >&2
echo "" >&2

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
PNG_ONLY=false
CUSTOM_HOST=""
CUSTOM_PORT=""

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --png) PNG_ONLY=true; shift ;;
    --host) CUSTOM_HOST="$2"; shift 2 ;;
    --port) CUSTOM_PORT="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: hermes-pair [--png] [--host HOST] [--port PORT]"
      echo ""
      echo "Generate a QR code for pairing mobile devices with the Hermes API server."
      echo "Reads API_SERVER_KEY, API_SERVER_HOST, API_SERVER_PORT from $HERMES_HOME/.env"
      echo ""
      echo "Options:"
      echo "  --png          Save PNG to /tmp/hermes-pairing-qr.png only (no terminal QR)"
      echo "  --host HOST    Override server host (default: auto-detect LAN IP)"
      echo "  --port PORT    Override server port (default: 8642)"
      echo "  -h, --help     Show this help"
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# Check qrencode
if ! command -v qrencode &>/dev/null; then
  echo "Error: qrencode not installed. Run: sudo apt install qrencode"
  exit 1
fi

# Read .env
API_KEY=$(grep -s '^API_SERVER_KEY=' "$HERMES_HOME/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'"'" || true)
HOST=$(grep -s '^API_SERVER_HOST=' "$HERMES_HOME/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'"'" || true)
PORT=$(grep -s '^API_SERVER_PORT=' "$HERMES_HOME/.env" 2>/dev/null | head -1 | cut -d= -f2- | tr -d '"'"'" || true)

# Apply defaults and overrides
HOST="${CUSTOM_HOST:-${HOST:-127.0.0.1}}"
PORT="${CUSTOM_PORT:-${PORT:-8642}}"

# Resolve LAN IP if bind-all or loopback
if [ "$HOST" = "0.0.0.0" ] || [ "$HOST" = "127.0.0.1" ] || [ "$HOST" = "localhost" ]; then
  RESOLVED=$(ip route get 1.1.1.1 2>/dev/null | grep -oP 'src \K\S+' || hostname -I 2>/dev/null | awk '{print $1}' || true)
  if [ -n "$RESOLVED" ]; then
    HOST="$RESOLVED"
  fi
fi

# Build compact JSON payload
PAYLOAD=$(python3 -c "import json; print(json.dumps({'hermes':1,'host':'$HOST','port':$PORT,'key':'$API_KEY','tls':False}, separators=(',',':')))")

# Auth status
if [ -n "$API_KEY" ]; then
  AUTH="Bearer token configured"
else
  AUTH="NO AUTH (open access)"
fi

if [ "$PNG_ONLY" = true ]; then
  echo "$PAYLOAD" | qrencode -t PNG -o /tmp/hermes-pairing-qr.png -s 8
  echo "PNG saved: /tmp/hermes-pairing-qr.png"
  echo "Server: http://$HOST:$PORT"
  echo "Auth:   $AUTH"
  exit 0
fi

# Terminal output
echo ""
echo "  Hermes API Server Pairing"
echo ""
echo "  Server: http://$HOST:$PORT"
echo "  Auth:   $AUTH"
echo ""
echo "$PAYLOAD" | qrencode -t UTF8 -o -
echo ""
# Also save PNG
echo "$PAYLOAD" | qrencode -t PNG -o /tmp/hermes-pairing-qr.png -s 8 2>/dev/null
echo "  PNG: /tmp/hermes-pairing-qr.png"
echo "  Scan with Hermes-Relay or any QR reader."
echo "  WARNING: This QR contains your API key — do not share screenshots."
echo ""
