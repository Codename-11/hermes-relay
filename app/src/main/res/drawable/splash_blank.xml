<?xml version="1.0" encoding="utf-8"?>
<!-- Blank/transparent splash icon — system splash shows as plain dark screen,
     then our Compose sphere intro takes over seamlessly.

     The path is a REAL (fully transparent) rect, not an empty vector: some
     OEM splash implementations (observed on OneUI / S25 Ultra) treat a
     pathless vector as an invalid icon and fall back to drawing the
     launcher mark instead. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:fillColor="#00000000"
        android:pathData="M0,0h108v108h-108z" />
</vector>
