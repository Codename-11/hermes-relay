<?xml version="1.0" encoding="utf-8"?>
<!--
    Sideload flavor manifest overlay.

    Merged on top of `app/src/main/AndroidManifest.xml` for the `sideloadDebug`
    / `sideloadRelease` variants. This track is NOT shipped through Google Play.

    The AccessibilityService is declared exactly once in `app/src/main/AndroidManifest.xml`.
    The flavor distinction is purely at the resource layer: this flavor's
    `res/xml/accessibility_service_config.xml` carries the full agent-control
    config (`canPerformGestures="true"`, `flagRetrieveInteractiveWindows`, etc.)
    and `res/values/strings.xml` carries the matching description string.
    Gradle's resource merger picks the right files at build time, so we don't
    need to redeclare the <service> here.

    This file is intentionally kept as an empty overlay so future flavor-specific
    permissions / activities have an obvious home. Mirror structural additions
    in `app/src/googlePlay/AndroidManifest.xml` unless the change is intentionally
    track-specific.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        Tier C (C1-C4) sideload-only permissions.

        These are deliberately NOT declared in the main manifest: Google Play
        policy forbids CALL_PHONE / SEND_SMS / READ_CONTACTS without a default-
        dialer / default-SMS-app justification, and ACCESS_FINE_LOCATION is
        flagged alongside auto-dial on the `googlePlay` track. The `sideload`
        flavor is the only track that ships them.

        Each of the four `android_*` tools (location, search_contacts, call,
        send_sms) runtime-checks the corresponding permission in
        `ActionExecutor` and returns a helpful error if the user hasn't granted
        it in system Settings. The tools themselves are additionally flavor-
        gated in `BridgeCommandHandler` so the googlePlay build returns
        `sideload-only` 403s instead of crashing on a missing permission.

        Source: docs/plans/2026-04-13-bridge-feature-expansion.md § Tier C.
    -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Screen recording — sideload only. googlePlay doesn't declare
         /screenshot or the MEDIA_PROJECTION FGS type. See the main
         manifest's comment on why the permission was moved here. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!--
        Override the BridgeForegroundService's foregroundServiceType to
        ADD mediaProjection on the sideload track. The main manifest
        declares specialUse only (so googlePlay lint passes without the
        MEDIA_PROJECTION permission); sideload upgrades to both types
        since it ships FOREGROUND_SERVICE_MEDIA_PROJECTION and the
        /screenshot route.
    -->
    <application>
        <service
            android:name=".bridge.BridgeForegroundService"
            android:foregroundServiceType="specialUse|mediaProjection"
            tools:replace="android:foregroundServiceType" />
    </application>

</manifest>
