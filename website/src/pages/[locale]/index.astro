---
import LandingPage from '../index.astro';
import { localizedLocales, type Locale } from '../../i18n';

export function getStaticPaths() {
  return localizedLocales.map((locale) => ({ params: { locale }, props: { locale } }));
}

const { locale } = Astro.props as { locale: Locale };
---

<LandingPage locale={locale} />
