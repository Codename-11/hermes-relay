---
import '@fontsource/space-grotesk/400.css';
import '@fontsource/space-grotesk/500.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '@fontsource/space-mono/400.css';
import '../styles/global.css';
import MorphingSphere from '../components/MorphingSphere.astro';
import { localeInfo, locales, translations, type Locale } from '../i18n';
import versionCatalog from '../../../gradle/libs.versions.toml?raw';

type Props = { locale?: Locale };

const locale = (Astro.props as Props).locale ?? 'en';
const copy = translations[locale];
const route = localeInfo[locale];
const docsUrl = `https://hermes-relay.dev${route.docsPath}`;
const canonicalDocsUrl = 'https://hermes-relay.dev/docs/';
const githubUrl = 'https://github.com/Codename-11/hermes-relay';
const playUrl = 'https://play.google.com/store/apps/details?id=com.axiomlabs.hermesrelay';
const cliUrl = `${canonicalDocsUrl}desktop/`;
const koFiUrl = 'https://ko-fi.com/L4L31Q8LJ1';
const quickStartUrl = `${docsUrl}guide/quick-start`;
const relayPluginUrl = `${docsUrl}guide/release-tracks`;
const currentVersion = versionCatalog.match(/^appVersionName\s*=\s*"([^"]+)"/m)?.[1] ?? '1.4.5';
const currentReleaseUrl = `${githubUrl}/releases/tag/android-v${currentVersion}`;
const pageTitle = copy.metadata.title;
const pageDescription = copy.metadata.description;
const canonicalUrl = Astro.site ? new URL(route.path, Astro.site).href : undefined;
const socialImageUrl = Astro.site ? new URL('/social-card.png', Astro.site).href : undefined;
const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Hermes-Relay',
  description: pageDescription,
  url: canonicalUrl,
  image: socialImageUrl,
  applicationCategory: 'UtilitiesApplication',
  operatingSystem: 'Android, Windows, macOS, Linux',
  softwareVersion: currentVersion,
  isAccessibleForFree: true,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  downloadUrl: playUrl,
  codeRepository: githubUrl,
  sameAs: [githubUrl, playUrl],
  inLanguage: locale,
  featureList: copy.metadata.features,
};
---

<!doctype html>
<html lang={locale} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark light" />
    <meta name="theme-color" content="#050609" />
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {locales.map((alternate) => (
      <link rel="alternate" hreflang={alternate} href={Astro.site ? new URL(localeInfo[alternate].path, Astro.site).href : localeInfo[alternate].path} />
    ))}
    <link rel="alternate" hreflang="x-default" href={Astro.site ? new URL('/', Astro.site).href : '/'} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Hermes-Relay" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    {socialImageUrl && <meta property="og:image" content={socialImageUrl} />}
    {socialImageUrl && <meta property="og:image:secure_url" content={socialImageUrl} />}
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={copy.metadata.imageAlt} />
    <meta property="og:locale" content={route.ogLocale} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    {socialImageUrl && <meta name="twitter:image" content={socialImageUrl} />}
    <meta name="twitter:image:alt" content={copy.metadata.imageAlt} />

    <link rel="icon" type="image/svg+xml" href="/brand/logo.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <title>{pageTitle}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>
    <script is:inline>
      (() => {
        try {
          const saved = localStorage.getItem('hermes-relay-theme');
          const theme = saved === 'light' || saved === 'dark'
            ? saved
            : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
          document.documentElement.style.colorScheme = theme;
        } catch {
          document.documentElement.dataset.theme = 'dark';
        }
      })();
    </script>
  </head>
  <body>
    <header class="site-header" data-header>
      <div class="header-identity">
        <a class="brand" href="#top" aria-label={copy.header.home}>
          <img src="/brand/logo.svg" alt="" width="28" height="28" />
          <span>Hermes-Relay</span>
        </a>
        <a class="version-badge" href={currentReleaseUrl} aria-label={`v${currentVersion}, ${copy.header.release}`}>
          v{currentVersion}
        </a>
        <span class="header-tagline">{copy.header.tagline}</span>
      </div>

      <div class="header-actions">
        <nav class="desktop-nav" aria-label={copy.header.mainNav}>
          <a href="#product">{copy.header.product}</a>
          <a href="#android">{copy.header.android}</a>
          <a href="#cli">CLI</a>
          <a href={docsUrl}>{copy.header.docs}</a>
          <a href={githubUrl}>GitHub <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
        </nav>

        <div class="language-picker" data-language-picker>
          <button
            class="language-trigger"
            type="button"
            aria-label={`${copy.header.language}: ${localeInfo[locale].label}`}
            aria-expanded="false"
            aria-controls="language-menu"
            data-language-trigger
          >
            <i class="ph ph-translate" aria-hidden="true"></i>
            <span>{localeInfo[locale].label}</span>
            <i class="ph ph-caret-down language-caret" aria-hidden="true"></i>
          </button>
          <nav class="language-menu" id="language-menu" aria-label={copy.header.language} data-language-menu hidden>
            <span class="language-menu-label">{copy.header.language}</span>
            {locales.map((option) => (
              <a href={localeInfo[option].path} lang={option} aria-current={option === locale ? 'page' : undefined}>
                <span class="language-code">{option === 'pt-BR' ? 'PT' : option === 'zh-CN' ? 'ZH' : option.toUpperCase()}</span>
                <strong>{localeInfo[option].label}</strong>
                {option === locale && <i class="ph ph-check" aria-hidden="true"></i>}
              </a>
            ))}
          </nav>
        </div>

        <button
          class="theme-toggle"
          type="button"
          aria-label={copy.header.lightTheme}
          title={copy.header.lightTheme}
          data-light-label={copy.header.lightTheme}
          data-dark-label={copy.header.darkTheme}
        >
          <i class="ph ph-sun" aria-hidden="true"></i>
        </button>

        <button class="menu-button" type="button" aria-expanded="false" aria-controls="mobile-nav">
          <span class="sr-only">{copy.header.openNav}</span>
          <i class="ph ph-list" aria-hidden="true"></i>
        </button>
      </div>

      <nav class="mobile-nav" id="mobile-nav" aria-label={copy.header.mobileNav} hidden>
        <a href="#product">{copy.header.product}</a>
        <a href="#android">{copy.header.android}</a>
        <a href="#cli">CLI</a>
        <a href={docsUrl}>{copy.header.docs}</a>
        <a href={githubUrl}>GitHub <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
      </nav>
    </header>

    <main id="top">
      <section class="hero" id="product" aria-labelledby="hero-title">
        <MorphingSphere variant="ambient" />
        <div class="hero-copy reveal">
          <p class="eyebrow"><span class="live-dot"></span> {copy.hero.eyebrow}</p>
          <h1 id="hero-title">{copy.hero.title} <span>{copy.hero.accent}</span></h1>
          <p class="hero-lede">{copy.hero.lede}</p>
          <div class="hero-actions">
            <a class="button button-primary" href={playUrl}>
              <i class="ph ph-android-logo" aria-hidden="true"></i>
              {copy.hero.androidCta}
            </a>
            <a class="button button-secondary" href={cliUrl}>
              <i class="ph ph-terminal-window" aria-hidden="true"></i>
              {copy.hero.cliCta}
            </a>
          </div>
          <p class="trust-line">{copy.hero.openSource} <span>·</span> {copy.hero.selfHosted} <span>·</span> {copy.hero.noCloud} <i></i></p>
        </div>

        <div class="hero-product reveal" aria-label={copy.hero.preview}>
          <div class="phone phone-hero">
            <span class="phone-speaker" aria-hidden="true"></span>
            <img
              src="/product/chat.png"
              srcset="/product/chat-260.webp 260w, /product/chat-520.webp 520w, /product/chat.png 1040w"
              sizes="(max-width: 720px) 250px, (max-width: 980px) 370px, 430px"
              width="1040"
              height="2160"
              alt={copy.hero.imageAlt}
              fetchpriority="high"
              decoding="async"
            />
          </div>
          <p class="route-label"><span></span> {copy.hero.route}</p>
        </div>
      </section>

      <section class="surface-section" aria-labelledby="surface-title">
        <header class="section-intro reveal">
          <p class="section-kicker">{copy.surfaces.kicker}</p>
          <h2 id="surface-title">{copy.surfaces.title}</h2>
          <p>{copy.surfaces.lede}</p>
        </header>

        <div class="surface-grid">
          <article class="surface surface-android reveal" id="android">
            <p class="surface-label"><span></span> Android</p>
            <h3>{copy.surfaces.androidTitle}</h3>
            <p class="surface-copy">{copy.surfaces.androidLede}</p>

            <div class="android-showcase">
              <div class="phone phone-small">
                <span class="phone-speaker" aria-hidden="true"></span>
                <img
                  src="/product/chat.png"
                  srcset="/product/chat-260.webp 260w, /product/chat-520.webp 520w, /product/chat.png 1040w"
                  sizes="(max-width: 720px) 200px, 250px"
                  width="1040"
                  height="2160"
                  alt={copy.hero.imageAlt}
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <ul class="feature-list">
                <li>
                  <i class="ph ph-chats-circle" aria-hidden="true"></i>
                  <span><strong>Chat</strong><small>{copy.surfaces.chatDescription}</small></span>
                </li>
                <li>
                  <i class="ph ph-waveform" aria-hidden="true"></i>
                  <span><strong>Voice</strong><small>{copy.surfaces.voiceDescription}</small></span>
                </li>
                <li>
                  <i class="ph ph-sliders-horizontal" aria-hidden="true"></i>
                  <span><strong>Manage</strong><small>{copy.surfaces.manageDescription}</small></span>
                </li>
              </ul>
            </div>

            <div class="screen-strip" aria-label={copy.surfaces.additional}>
              <figure>
                <MorphingSphere variant="voice" />
                <figcaption>Voice</figcaption>
              </figure>
              <figure>
                <img
                  src="/product/manage.png"
                  srcset="/product/manage-360.webp 360w, /product/manage-720.webp 720w, /product/manage.png 1080w"
                  sizes="(max-width: 720px) 45vw, (max-width: 980px) 38vw, 280px"
                  width="1080"
                  height="2160"
                  alt="Hermes-Relay Manage screen"
                  loading="lazy"
                  decoding="async"
                />
                <figcaption>Manage</figcaption>
              </figure>
            </div>
          </article>

          <article class="surface surface-cli reveal" id="cli">
            <p class="surface-label surface-label-cli"><span></span> CLI</p>
            <h3>{copy.surfaces.cliTitle}</h3>
            <p class="surface-copy">{copy.surfaces.cliLede}</p>

            <div class="terminal" aria-label={copy.surfaces.terminal}>
              <div class="terminal-bar">
                <i class="ph ph-terminal-window" aria-hidden="true"></i>
                <span>hermes@machine:~</span>
              </div>
              <div class="terminal-body">
                <p><span class="prompt">$</span> hermes-relay</p>
                <p class="terminal-muted">Connecting…</p>
                <p><span class="terminal-ok">Connected via Tailscale (secure)</span><br />server 0.6.0</p>
                <p>Attached · tmux session “default”<br /><span class="terminal-muted">re-attached with scrollback</span></p>
                <p>Desktop tools · 23 handlers advertised</p>
                <p class="terminal-ready">❯ <b></b></p>
                <span class="terminal-live"><i></i> attached</span>
              </div>
            </div>

            <div class="consent-note">
              <i class="ph ph-shield-check" aria-hidden="true"></i>
              <div>
                <strong>{copy.surfaces.consentTitle}</strong>
                <p>{copy.surfaces.consentBody}</p>
              </div>
            </div>

            <div class="cli-capability-grid" aria-label={copy.surfaces.capabilities}>
              <article class="cli-capability">
                <div class="cli-capability-command">
                  <i class="ph ph-arrow-counter-clockwise" aria-hidden="true"></i>
                  <code>hermes-relay sessions</code>
                </div>
                <h4>{copy.surfaces.sessionsTitle}</h4>
                <p>{copy.surfaces.sessionsBody}</p>
              </article>
              <article class="cli-capability">
                <div class="cli-capability-command">
                  <i class="ph ph-lightning" aria-hidden="true"></i>
                  <code>hermes-relay daemon status</code>
                </div>
                <h4>{copy.surfaces.daemonTitle}</h4>
                <p>{copy.surfaces.daemonBody}</p>
              </article>
              <article class="cli-capability cli-capability--wide">
                <div class="cli-capability-command">
                  <i class="ph ph-list-checks" aria-hidden="true"></i>
                  <code>hermes-relay audit</code>
                </div>
                <h4>{copy.surfaces.auditTitle}</h4>
                <p>{copy.surfaces.auditBody}</p>
              </article>
            </div>

            <a class="text-link" href={cliUrl}>{copy.surfaces.meetCli} <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
          </article>
        </div>
      </section>

      <section id="device-control" class="device-control reveal" aria-labelledby="device-control-title">
        <div class="device-control-copy">
          <p class="eyebrow"><span class="live-dot"></span> {copy.device.eyebrow}</p>
          <h2 id="device-control-title">{copy.device.title}</h2>
          <p class="device-control-lede">{copy.device.lede}</p>

          <div class="device-control-capabilities" aria-label={copy.device.capabilities}>
            <span><i class="ph ph-eye" aria-hidden="true"></i> {copy.device.read}</span>
            <span><i class="ph ph-hand-tap" aria-hidden="true"></i> {copy.device.tap}</span>
            <span><i class="ph ph-keyboard" aria-hidden="true"></i> {copy.device.type}</span>
          </div>

          <div class="device-control-gate">
            <i class="ph ph-shield-check" aria-hidden="true"></i>
            <div>
              <strong>{copy.device.gateTitle}</strong>
              <p>{copy.device.gateBody}</p>
            </div>
          </div>

          <a class="text-link" href={relayPluginUrl}>
            {copy.device.link} <i class="ph ph-arrow-right" aria-hidden="true"></i>
          </a>
        </div>

        <div class="bridge-preview" role="img" aria-label={copy.device.preview}>
          <div class="bridge-preview-bar">
            <span><i class="ph ph-caret-left" aria-hidden="true"></i> Bridge</span>
            <i class="ph ph-sliders-horizontal" aria-hidden="true"></i>
          </div>

          <div class="bridge-preview-body">
            <div class="bridge-paired-card">
              <div>
                <span class="bridge-preview-kicker">PHONE BRIDGE</span>
                <strong>Phone bridge is paired</strong>
                <p>Advanced phone controls share this local grant.</p>
              </div>
              <div class="bridge-status-pills" aria-label="Relay and safety ready">
                <span><i></i> relay</span>
                <span><i></i> safety</span>
              </div>
            </div>

            <div class="bridge-control-grid">
              <div class="bridge-control-card">
                <div class="bridge-control-heading">
                  <div>
                    <span>AGENT CONTROL</span>
                    <strong>Agent Control</strong>
                  </div>
                  <div class="bridge-master-toggle" aria-label="Master control on">
                    <span>MASTER</span><i></i>
                  </div>
                </div>
                <p>Hermes can read the screen and act through the controls below.</p>
                <dl class="bridge-device-status">
                  <div><dt><i class="ph ph-device-mobile" aria-hidden="true"></i> Device</dt><dd>Pixel · ready</dd></div>
                  <div><dt><i class="ph ph-battery-high" aria-hidden="true"></i> Battery</dt><dd>87%</dd></div>
                  <div><dt><i class="ph ph-app-window" aria-hidden="true"></i> Current app</dt><dd>Messages</dd></div>
                </dl>
              </div>

              <div class="bridge-safety-card">
                <div class="bridge-card-title">
                  <span><i class="ph ph-shield-check" aria-hidden="true"></i> Safety</span>
                  <i class="ph ph-caret-right" aria-hidden="true"></i>
                </div>
                <dl>
                  <div><dt>Apps the agent can't touch</dt><dd>6</dd></div>
                  <div><dt>Words that always ask first</dt><dd>12</dd></div>
                  <div><dt>Turns itself off when idle</dt><dd>30 min</dd></div>
                </dl>
              </div>
            </div>

            <div class="bridge-activity-card">
              <div class="bridge-card-title">
                <span><i class="ph ph-list-checks" aria-hidden="true"></i> Activity Log</span>
                <span class="bridge-live-label"><i></i> LIVE</span>
              </div>
              <div class="bridge-activity-row">
                <span class="bridge-activity-icon"><i class="ph ph-hand-tap" aria-hidden="true"></i></span>
                <div><strong>Tap “Send”</strong><span>Messages · just now</span></div>
                <span class="bridge-activity-result"><i class="ph ph-check" aria-hidden="true"></i> Allowed</span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="setup-path reveal" aria-labelledby="setup-title">
        <div class="setup-path-copy">
          <p class="eyebrow">{copy.setup.eyebrow}</p>
          <h2 id="setup-title">{copy.setup.title}</h2>
          <p>{copy.setup.body}</p>
        </div>
        <div class="setup-path-links" aria-label={copy.setup.resources}>
          <a class="button button-primary" href={playUrl}>
            <i class="ph ph-android-logo" aria-hidden="true"></i>
            {copy.setup.androidCta}
          </a>
          <a class="button button-secondary" href={quickStartUrl}>
            {copy.setup.quickStart} <i class="ph ph-arrow-right" aria-hidden="true"></i>
          </a>
          <a class="text-link" href={relayPluginUrl}>
            {copy.setup.plugin} <i class="ph ph-arrow-right" aria-hidden="true"></i>
          </a>
        </div>
      </section>

      <section class="privacy-band reveal" aria-label={copy.privacy.aria}>
        <i class="ph ph-lock-key-open" aria-hidden="true"></i>
        <div>
          <h2>{copy.privacy.title}</h2>
          <p>{copy.privacy.body}</p>
        </div>
        <div class="privacy-actions">
          <a href={docsUrl}>{copy.privacy.learn} <i class="ph ph-arrow-right" aria-hidden="true"></i></a>
          <a href={koFiUrl}>{copy.privacy.support} <i class="ph ph-arrow-up-right" aria-hidden="true"></i></a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="footer-brand">
        <a class="brand" href="#top">
          <img src="/brand/logo.svg" alt="" width="26" height="26" />
          <span>Hermes-Relay</span>
        </a>
        <p>{copy.footer.tagline}</p>
      </div>
      <div class="footer-column">
        <h2>{copy.footer.product}</h2>
        <a href={playUrl}>{copy.footer.android}</a>
        <a href={cliUrl}>CLI</a>
        <a href="#android">{copy.footer.features}</a>
      </div>
      <div class="footer-column">
        <h2>{copy.footer.resources}</h2>
        <a href={quickStartUrl}>{copy.footer.quickStart}</a>
        <a href={relayPluginUrl}>{copy.footer.plugin}</a>
        <a href={docsUrl}>{copy.footer.docs}</a>
      </div>
      <div class="footer-column">
        <h2>{copy.footer.project}</h2>
        <a href={githubUrl}>GitHub</a>
        <a href={`${githubUrl}/releases`}>{copy.footer.releases}</a>
        <a href={`${githubUrl}/blob/main/CONTRIBUTING.md`}>{copy.footer.contributing}</a>
        <a href={`${canonicalDocsUrl}architecture/security.html`}>{copy.footer.security}</a>
      </div>
      <div class="footer-bottom">
        <span>
          {copy.footer.builtFor} <a href="https://hermes-agent.nousresearch.com">Hermes Agent</a> {copy.footer.by}{' '}
          <a href="https://codename-11.dev">Axiom-Labs</a>
        </span>
        <a href={`${githubUrl}/blob/main/LICENSE`}>{copy.footer.license}</a>
      </div>
    </footer>

    <script>
      const button = document.querySelector('.menu-button');
      const menu = document.querySelector('#mobile-nav');
      const menuIcon = button?.querySelector('i');
      const themeButton = document.querySelector('.theme-toggle');
      const themeIcon = themeButton?.querySelector('i');
      const themeColor = document.querySelector('meta[name="theme-color"]');
      const languagePicker = document.querySelector('[data-language-picker]');
      const languageTrigger = document.querySelector('[data-language-trigger]');
      const languageMenu = document.querySelector('[data-language-menu]');

      const applyTheme = (theme: string | undefined) => {
        const nextTheme = theme === 'light' ? 'light' : 'dark';
        document.documentElement.dataset.theme = nextTheme;
        document.documentElement.style.colorScheme = nextTheme;
        const nextLabel = nextTheme === 'dark'
          ? themeButton?.getAttribute('data-light-label')
          : themeButton?.getAttribute('data-dark-label');
        if (!nextLabel) return;
        themeButton?.setAttribute('aria-label', nextLabel);
        themeButton?.setAttribute('title', nextLabel);
        themeIcon?.classList.toggle('ph-sun', nextTheme === 'dark');
        themeIcon?.classList.toggle('ph-moon', nextTheme === 'light');
        themeColor?.setAttribute('content', nextTheme === 'dark' ? '#050609' : '#f4f4f1');
      };

      applyTheme(document.documentElement.dataset.theme);

      themeButton?.addEventListener('click', () => {
        const nextTheme = document.documentElement.dataset.theme === 'light' ? 'dark' : 'light';
        applyTheme(nextTheme);
        try {
          localStorage.setItem('hermes-relay-theme', nextTheme);
        } catch {
          // Theme still applies for this page view when storage is unavailable.
        }
      });

      const closeLanguageMenu = () => {
        if (!(languageTrigger instanceof HTMLButtonElement) || !(languageMenu instanceof HTMLElement)) return;
        languageTrigger.setAttribute('aria-expanded', 'false');
        languageMenu.hidden = true;
      };

      languageTrigger?.addEventListener('click', () => {
        if (!(languageTrigger instanceof HTMLButtonElement) || !(languageMenu instanceof HTMLElement)) return;
        const open = languageTrigger.getAttribute('aria-expanded') === 'true';
        languageTrigger.setAttribute('aria-expanded', String(!open));
        languageMenu.hidden = open;
      });

      document.addEventListener('click', (event) => {
        if (!(event.target instanceof Node) || languagePicker?.contains(event.target)) return;
        closeLanguageMenu();
      });

      document.addEventListener('keydown', (event) => {
        if (event.key !== 'Escape' || languageMenu?.hasAttribute('hidden')) return;
        closeLanguageMenu();
        if (languageTrigger instanceof HTMLButtonElement) languageTrigger.focus();
      });

      const closeMenu = () => {
        if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;
        button.setAttribute('aria-expanded', 'false');
        menu.hidden = true;
        menuIcon?.classList.remove('ph-x');
        menuIcon?.classList.add('ph-list');
      };

      button?.addEventListener('click', () => {
        if (!(button instanceof HTMLButtonElement) || !(menu instanceof HTMLElement)) return;
        const open = button.getAttribute('aria-expanded') === 'true';
        button.setAttribute('aria-expanded', String(!open));
        menu.hidden = open;
        menuIcon?.classList.toggle('ph-list', open);
        menuIcon?.classList.toggle('ph-x', !open);
      });

      menu?.querySelectorAll('a').forEach((link) => link.addEventListener('click', closeMenu));
    </script>
  </body>
</html>
